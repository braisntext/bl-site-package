{%- set pageTitleMap = {
  "index": site.page_index_title or site.company_name or "Inicio",
  "quienes": site.page_quienes_title or "Quiénes somos",
  "servicios": site.page_servicios_title or "Servicios",
  "contacto": site.page_contacto_title or "Contacto",
  "blog": site.page_blog_title or "Blog",
  "productos": "Catálogo"
} -%}
{%- set pageDescMap = {
  "index": site.page_index_desc or site.page_index_subtitle or "",
  "quienes": site.page_quienes_desc or site.page_quienes_subtitle or "",
  "servicios": site.page_servicios_desc or site.page_servicios_subtitle or "",
  "contacto": site.page_contacto_desc or site.page_contacto_subtitle or "",
  "blog": site.page_blog_subtitle or "",
  "productos": "Reserva online y recoge en tienda"
} -%}
{%- set resolvedTitle = title or pageTitleMap[navActive] or site.company_name -%}
{%- set resolvedDesc = description or pageDescMap[navActive] or "" -%}
{%- set fullTitle = (resolvedTitle + " | " + site.company_name) if (resolvedTitle and site.company_name and resolvedTitle != site.company_name) else (resolvedTitle or site.company_name) -%}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ fullTitle }}</title>
  <meta name="description" content="{{ resolvedDesc }}">
  <meta property="og:title" content="{{ fullTitle }}">
  <meta property="og:description" content="{{ resolvedDesc }}">
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div id="site-root">
    <nav class="site-nav">
      <div class="site-nav-inner">
        <a href="/" class="site-nav-brand">
          {%- if site.logo_ext -%}
          <img src="/uploads/logo.{{ site.logo_ext }}" alt="{{ site.company_name }}" class="site-logo-img">
          {%- else -%}
          <div class="site-logo-placeholder"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
          {%- endif -%}
          <span>{{ site.company_name or "Mi empresa" }}</span>
        </a>
        <div class="site-nav-actions">
          <a href="/carrito" class="site-nav-icon-btn cart-icon-link" aria-label="Carrito">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span id="cart-count-badge" class="cart-count-badge" hidden>0</span>
          </a>
          <button id="theme-toggle" class="site-nav-icon-btn" aria-label="Cambiar tema"></button>
          <button class="site-nav-toggle" aria-label="Menú" onclick="this.closest('nav').querySelector('.site-nav-links').classList.toggle('open')">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          </button>
        </div>
        <div class="site-nav-links">
          <a href="/" class="site-nav-link{% if navActive == 'index' %} active{% endif %}">Inicio</a>
          <a href="/quienes-somos" class="site-nav-link{% if navActive == 'quienes' %} active{% endif %}">Quiénes somos</a>
          <a href="/servicios" class="site-nav-link{% if navActive == 'servicios' %} active{% endif %}">Servicios</a>
          <a href="/contacto" class="site-nav-link{% if navActive == 'contacto' %} active{% endif %}">Contacto</a>
          <a href="/blog" class="site-nav-link{% if navActive == 'blog' %} active{% endif %}">Blog</a>
          <a href="/productos" class="site-nav-link{% if navActive == 'productos' %} active{% endif %}">Catálogo</a>
        </div>
      </div>
    </nav>

    {{ content | safe }}

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span>{% if site.company_name %}© {{ site.year }} {{ site.company_name }}{% endif %}</span>
        <div class="site-footer-links">
          <a href="/quienes-somos">Quiénes somos</a>
          <a href="/servicios">Servicios</a>
          <a href="/contacto">Contacto</a>
          <a href="/blog">Blog</a>
          <a href="/productos">Catálogo</a>
        </div>
      </div>
    </footer>
    <div id="cookie-banner" role="dialog" aria-live="polite" aria-label="Aviso de cookies">
      <p>Usamos cookies propias para mejorar tu experiencia. Sin tracking de terceros.</p>
      <button id="cookie-accept" class="site-btn">Aceptar</button>
    </div>
    {%- if site.whatsapp_number %}
    <a href="https://wa.me/{{ site.whatsapp_number }}?text={{ ("Hola, me interesa " + (site.company_name or "vuestra empresa")) | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp" class="whatsapp-float"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a>
    {%- endif %}
  </div>
  <script src="/site.js"></script>
  <script src="/cart.js" defer></script>
</body>
</html>
