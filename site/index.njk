---
layout: base.njk
navActive: index
---
{%- if not site.page_index_title %}
<div class="construction-wrap"><div class="construction-icon">🚧</div><h1>Página en construcción</h1><p>Estamos preparando esta página. Vuelve pronto.</p><a href="/" class="site-btn">Volver al inicio</a></div>
{%- else %}
<main class="site-hero"><div class="site-hero-inner">
  <h1 class="reveal">{{ site.page_index_title | safe }}</h1>
  {%- if site.page_index_subtitle %}
  <p class="site-hero-subtitle reveal">{{ site.page_index_subtitle | safe }}</p>
  {%- endif %}
  {%- if site.page_index_desc %}
  <p class="site-hero-desc reveal">{{ site.page_index_desc | safe }}</p>
  {%- endif %}
  <div class="site-hero-actions reveal"><a href="/servicios" class="site-btn">Ver servicios</a><a href="/contacto" class="site-btn-ghost">Contactar</a></div>
</div></main>
{%- endif %}
