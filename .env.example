# Puerto del servidor
PORT=3000

# Contraseña del panel — se configura en el wizard
PANEL_PASSWORD=

# Secret JWT — se genera automáticamente en el wizard
JWT_SECRET=

# OpenRouter API Key — se configura en el wizard
OPENROUTER_API_KEY=

# Modelo IA para el agente de contenidos
CONTENT_AGENT_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Nombre y sector de la empresa — se configuran en el wizard
CLIENT_COMPANY_NAME=
CLIENT_SECTOR=

# Ruta a la base de datos SQLite
DB_PATH=./data/app.db

# URL pública definitiva del sitio (canonical, Open Graph, sitemap.xml).
# Sobrescribe el valor del panel. Sin barra final. Ej: https://miempresa.com
SITE_URL=

# STAGING=true añade X-Robots-Tag noindex y hace que robots.txt bloquee el
# rastreo y sitemap.xml quede vacío. Déjalo sin definir (o distinto de "true")
# en producción.
STAGING=

# Notificaciones de contacto (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password
NOTIFY_EMAIL=email_donde_recibes_mensajes@gmail.com

# Feed de catálogo Liderpapel (sFTP) — LIDERPAPEL_SFTP_PASS nunca debe
# commitearse; se guarda solo en el entorno de despliegue o en el panel.
LIDERPAPEL_SFTP_HOST=sftp.liderpapel.com
LIDERPAPEL_SFTP_PORT=22
LIDERPAPEL_SFTP_USER=20603
LIDERPAPEL_SFTP_PASS=
# "sftp" (feed real) o "local" (fixtures, ver fixtures/liderpapel/)
LIDERPAPEL_SYNC_MODE=sftp
LIDERPAPEL_LOCAL_DIR=
